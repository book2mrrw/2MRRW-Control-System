{
  "name": "2mrrw-control-system",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "next build",
    "typecheck": "tsc --noEmit",
    "ingest:frontend": "node --conditions react-server --import tsx scripts/ingest-frontend.ts",
    "backfill:covers": "node --conditions react-server --import tsx scripts/backfill-storage-covers.ts",
    "trigger:cron": "bash scripts/trigger-scheduled-cron.sh",
    "import:frontend-releases": "node --conditions react-server --import tsx src/scripts/ingestFrontend.ts --activate",
    "export:frontend-releases-sql": "node --conditions react-server --import tsx src/scripts/exportFrontendReleasesSql.ts",
    "test": "node --conditions react-server --import tsx tests/stability-foundation.test.ts && node --conditions react-server --import tsx tests/backend-foundation.test.ts",
    "test:stability": "node --conditions react-server --import tsx tests/stability-foundation.test.ts",
    "verify": "npm run typecheck && npm run test",
    "foundation:recover": "bash scripts/run-foundation-recovery.sh",
    "foundation:verify": "bash scripts/verify-foundation-state.sh",
    "foundation:deploy": "bash scripts/run-foundation-deploy.sh",
    "foundation:rollback": "bash scripts/run-safe-rollback.sh",
    "foundation:checkpoint": "bash scripts/create-recovery-checkpoint.sh",
    "foundation:checkpoint-platform": "bash scripts/run-platform-foundation-checkpoint.sh",
    "foundation:recover-platform": "bash scripts/run-platform-foundation-recovery.sh",
    "foundation:verify-platform": "bash scripts/verify-platform-foundation-state.sh"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1052.0",
    "@aws-sdk/s3-request-presigner": "^3.1052.0",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "2.105.4",
    "lucide-react": "^1.16.0",
    "luxon": "^3.7.2",
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "server-only": "^0.0.1",
    "stripe": "22.1.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/luxon": "^3.7.1",
    "@types/node": "25.8.0",
    "@types/react": "19.2.14",
    "tsx": "4.22.1",
    "typescript": "6.0.3"
  }
}
