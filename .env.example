# Copy this file to .env.local for local development.
# Keep real values out of git and configure production values in Vercel.

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
# artist-platform reads catalog/hero from this URL (see artist-platform/.env.example)
NEXT_PUBLIC_CONTROL_SYSTEM_API_URL=https://2mrrw-control-system.vercel.app
VERCEL_PROJECT_ID=
VERCEL_ORG_ID=
CONTROL_SYSTEM_ALLOWED_ORIGINS=http://localhost:3000,https://artist-platform-silk.vercel.app
CONTROL_SYSTEM_FRONTEND_SHARED_SECRET=
CONTROL_SYSTEM_ADMIN_API_KEY=
# CRON_SECRET=  # Vercel Production only. Powers /api/cron/scheduled-releases and /api/admin/ops/backfill-covers.
# `vercel env pull .env.local` may redact this — copy once from Vercel dashboard if scripts fail.
# Quarterly rotation: Vercel → redeploy → GitHub secret CRON_SECRET → local .env.local

# CONTROL_SYSTEM_URL=https://2mrrw-control-system.vercel.app  # for scripts/trigger-scheduled-cron.sh

# Vercel Cron: Hobby = `0 6 * * *` in vercel.json. Pro = `*/5 * * * *`. Hobby alt: .github/workflows/scheduled-releases.yml

# --- Supabase (auth + database only) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key
# Prefer SUPABASE_SERVICE_ROLE_KEY; SUPABASE_SECRET_KEY is also supported for Vercel integrations.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
# SUPABASE_SECRET_KEY=your-supabase-secret-key

# DEPRECATED — Obsolete after R2 migration (f4b54e9). Do not add to new deployments.
# SUPABASE_MEDIA_BUCKET=protected-media

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Dev-only: allow control seed catalog webhook to grant in-memory demo entitlements (never in production).
# ALLOW_CONTROL_STRIPE_SEED=true

# --- Cloudflare R2 (all media storage + CDN) ---
# S3 API endpoint must NOT include bucket name in path
# Cloudflare R2 — use account ID in endpoint URL (not bucket name)
# S3 API endpoint: https://<CLOUDFLARE_R2_ACCOUNT_ID>.r2.cloudflarestorage.com
CLOUDFLARE_R2_ACCOUNT_ID=992d4f5d45e7c56189a518c2f417fe25
CLOUDFLARE_R2_ACCESS_KEY_ID=YOUR_R2_ACCESS_KEY
CLOUDFLARE_R2_SECRET_ACCESS_KEY=YOUR_R2_SECRET
CLOUDFLARE_R2_BUCKET_NAME=2mrrw-media
CLOUDFLARE_R2_ENDPOINT=https://992d4f5d45e7c56189a518c2f417fe25.r2.cloudflarestorage.com
# Cloudflare R2 public CDN base URL
NEXT_PUBLIC_R2_PUBLIC_URL=https://pub-643e4a94e0184b1fabf6522cfbb16f75.r2.dev
