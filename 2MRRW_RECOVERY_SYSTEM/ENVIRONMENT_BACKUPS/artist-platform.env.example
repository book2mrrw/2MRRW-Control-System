# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_CONTROL_SYSTEM_API_URL=https://2-mrrw-control-system.vercel.app

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
# From Stripe Dashboard → Webhooks → endpoint https://YOUR_DOMAIN/api/webhook
STRIPE_WEBHOOK_SECRET=
# Optional existing recurring Price/Product IDs for the Inner Circle subscription.
# If omitted locally, /api/memberships/checkout creates the Stripe product and inline recurring price data.
STRIPE_INNER_CIRCLE_PRICE_ID=
STRIPE_INNER_CIRCLE_PRODUCT_ID=

# Printful (merch fulfillment)
PRINTFUL_API_KEY=

# One-time product catalog seed (POST /api/admin/seed-products)
ADMIN_SEED_SECRET=

# Signs passwordless guest identity cookies. Generate a long random value.
GUEST_SESSION_SECRET=
